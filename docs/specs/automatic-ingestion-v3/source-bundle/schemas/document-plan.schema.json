{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/document-plan.schema.json",
  "title": "Document Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "graph_revision",
    "items",
    "publication_mode",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "graph_revision": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document_id",
          "document_type",
          "title",
          "canonical_claim_ids",
          "question_ids",
          "path"
        ],
        "properties": {
          "document_id": {
            "type": "string",
            "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
          },
          "document_type": {
            "enum": [
              "overview",
              "concept",
              "procedure",
              "interface_reference",
              "decision",
              "troubleshooting",
              "security_guide",
              "operational_guide",
              "glossary",
              "historical_note",
              "faq"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "canonical_claim_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
            }
          },
          "question_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
            }
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "audience": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "prerequisite_claim_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
            }
          }
        }
      }
    },
    "publication_mode": {
      "enum": [
        "evidence_graph_only",
        "coverage_and_gap_report",
        "provisional_questions_and_answers",
        "provisional_faq",
        "historical_archive",
        "canonical_documentation"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "superseded",
        "rejected"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
