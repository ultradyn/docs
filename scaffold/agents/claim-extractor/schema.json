{
  "type": "object",
  "additionalProperties": false,
  "required": ["claims"],
  "properties": {
    "claims": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "type",
          "scope",
          "authority",
          "lifecycle",
          "evidenceReferenceIds",
          "candidateRelationships"
        ],
        "properties": {
          "text": { "type": "string", "minLength": 1, "maxLength": 8000 },
          "type": {
            "enum": [
              "definition",
              "purpose",
              "behavior",
              "requirement",
              "constraint",
              "interface_contract",
              "procedure_step",
              "failure_mode",
              "rationale_documented",
              "example",
              "metric",
              "historical_fact",
              "unknown_boundary"
            ]
          },
          "scope": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            }
          },
          "authority": { "type": "string", "minLength": 1, "maxLength": 256 },
          "lifecycle": { "type": "string", "minLength": 1, "maxLength": 256 },
          "evidenceReferenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
              "type": "string",
              "pattern": "^unit-[0-9A-HJKMNP-TV-Z]{26}$"
            }
          },
          "candidateRelationships": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "qualifierClaimIds": {
                "type": "array",
                "maxItems": 64,
                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
              },
              "contradictsClaimIds": {
                "type": "array",
                "maxItems": 64,
                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
              },
              "supersedesClaimIds": {
                "type": "array",
                "maxItems": 64,
                "items": { "type": "string", "minLength": 1, "maxLength": 64 }
              }
            }
          }
        }
      }
    }
  }
}
