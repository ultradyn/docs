{
  "name": "@ultradyn/docs",
  "version": "0.1.0",
  "description": "Question-driven, Git-backed documentation that grows where people need answers.",
  "type": "module",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ultradyn/docs.git"
  },
  "homepage": "https://github.com/ultradyn/docs#readme",
  "bugs": "https://github.com/ultradyn/docs/issues",
  "bin": {
    "ultradyn-docs": "dist/bin.js"
  },
  "files": [
    "dist",
    "code",
    "docs",
    ".plan",
    "scaffold",
    "scripts",
    "tauri-app",
    ".codex/skills",
    "AGENTS.md",
    "CONTEXT.md",
    "BLOCKED_TASKS.md",
    "SECURITY.md",
    ".env.example",
    ".gitattributes",
    ".gitignore",
    ".prettierignore",
    ".npmignore",
    "eslint.config.js",
    "pnpm-workspace.yaml",
    "playwright.config.ts",
    "pnpm-lock.yaml",
    "skills-lock.json",
    "tsconfig.json",
    "vitest.config.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "build": "pnpm build:web && pnpm build:node",
    "build:node": "tsup code/cli/bin.ts --format esm --platform node --target node22 --out-dir dist --clean",
    "build:web": "vite build --config code/web/vite.config.ts",
    "dev": "tsx code/cli/bin.ts serve --dev",
    "start": "node dist/bin.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tui": "vitest run code/cli && node code/cli/test/tmux/run.mjs",
    "test:e2e": "playwright test",
    "test:integrity": "node --import tsx code/repository/check-projections.ts . && node --import tsx code/repository/check-raw.ts .",
    "test:package": "node scripts/package-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:integrity && pnpm build",
    "prepack": "pnpm check",
    "tauri:dev": "pnpm --dir tauri-app tauri dev",
    "tauri:build": "pnpm --dir tauri-app tauri build"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "ajv": "^8.20.0",
    "execa": "^9.6.1",
    "fastify": "^5.10.0",
    "is-unicode-supported": "^2.1.0",
    "lucide-react": "^1.24.0",
    "minisearch": "^7.2.0",
    "open": "^11.0.0",
    "openai": "^6.47.0",
    "picocolors": "^1.1.1",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "simple-git": "^3.36.0",
    "stemmer": "2.0.1",
    "string-width": "^8.2.2",
    "ulid": "^3.0.2",
    "wrap-ansi": "^10.0.0",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.10",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.1",
    "strip-ansi": "^7.1.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.7.0"
}
