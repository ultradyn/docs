{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultradyn.dev/schemas/ingest/data-rights-policy-profile.schema.json",
  "title": "DataRightsPolicyProfile",
  "description": "Expanded declarative data and rights policy profile. Additive to the frozen minimal PolicyProfile contract, which it does not redefine. Declarative only: no field here authorises deletion, erasure, or expiry of retained bytes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "dataRightsClass",
    "include",
    "exclude",
    "allowedMediaTypes",
    "allowedProcessors",
    "allowedProviders",
    "allowedStorage",
    "allowedRegions",
    "retentionClass",
    "retentionDays",
    "logging",
    "cache",
    "accessClass",
    "licenceRestrictions",
    "publication",
    "maxQuoteBytes",
    "maxFiles",
    "maxFileBytes",
    "maxExpandedBytes"
  ],
  "$comment": "Draft 2020-12 has no portable value-comparison keyword, so include/exclude disjointness and the licence-to-publication cross-field rules stay native-owned in the Zod schema. This file pins shape, vocabulary, and budgets only.",
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dataRightsClass": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted-local-only",
        "prohibited"
      ]
    },
    "include": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "exclude": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "allowedMediaTypes": {
      "$ref": "#/$defs/capabilityList"
    },
    "allowedProcessors": {
      "$ref": "#/$defs/capabilityList"
    },
    "allowedProviders": {
      "$ref": "#/$defs/capabilityList"
    },
    "allowedStorage": {
      "$ref": "#/$defs/capabilityList"
    },
    "allowedRegions": {
      "$ref": "#/$defs/capabilityList"
    },
    "retentionClass": {
      "enum": ["project-lifetime", "engagement-scoped", "session-scoped"]
    },
    "retentionDays": {
      "type": "integer",
      "minimum": 1
    },
    "logging": {
      "enum": ["none", "ids-only", "ids-and-paths"]
    },
    "cache": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["profileId", "principalId", "snapshotId"]
      }
    },
    "accessClass": {
      "type": "string",
      "minLength": 1
    },
    "licenceRestrictions": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "enum": [
          "no-redistribution",
          "no-derivatives",
          "no-verbatim-quotes",
          "attribution-required"
        ]
      }
    },
    "publication": {
      "enum": [
        "forbidden",
        "internal-only",
        "change-request-required",
        "external"
      ]
    },
    "maxQuoteBytes": {
      "type": "integer",
      "minimum": 0
    },
    "maxFiles": {
      "type": "integer",
      "minimum": 1
    },
    "maxFileBytes": {
      "type": "integer",
      "minimum": 1
    },
    "maxExpandedBytes": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "capabilityList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "not": {
          "pattern": "\\*"
        }
      }
    }
  }
}
