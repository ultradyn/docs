{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/coverage-entry.schema.json",
  "title": "Coverage Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "source_unit_id",
    "disposition",
    "reason",
    "linked_question_ids",
    "linked_claim_ids",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "source_unit_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "disposition": {
      "enum": [
        "unreviewed",
        "candidate_relevant",
        "represented_by_claim",
        "represented_by_question",
        "cited_primary",
        "cited_qualifying",
        "supplemental_selected",
        "duplicate_content",
        "superseded_or_deprecated",
        "historical_only",
        "boilerplate_or_navigation",
        "human_excluded",
        "unsupported_or_unreadable",
        "processing_failed"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "linked_question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "linked_claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
