{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packetId",
    "reviewerRunId",
    "extractorRunId",
    "reviews"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packetId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reviewerRunId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "extractorRunId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claimId",
          "expectedVersion",
          "decision",
          "entailment",
          "atomicity",
          "scope",
          "qualifiers",
          "authorityEligible"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "pattern": "^clm-[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "expectedVersion": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1000000
          },
          "decision": {
            "enum": ["accept", "reject", "qualify", "split"]
          },
          "entailment": {
            "enum": ["entailed", "not_entailed", "ambiguous"]
          },
          "atomicity": {
            "enum": ["atomic", "overbroad", "fragmented"]
          },
          "scope": {
            "enum": ["compatible", "wrong_scope", "ambiguous"]
          },
          "qualifiers": {
            "enum": ["complete", "missing", "n/a"]
          },
          "authorityEligible": { "type": "boolean" },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "splits": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["statement", "claimType", "scope"],
              "properties": {
                "statement": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 8000
                },
                "claimType": {
                  "enum": [
                    "definition",
                    "purpose",
                    "behavior",
                    "requirement",
                    "constraint",
                    "interface_contract",
                    "procedure_step",
                    "failure_mode",
                    "rationale_documented",
                    "example",
                    "metric",
                    "historical_fact",
                    "unknown_boundary"
                  ]
                },
                "scope": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "qualifierClaimIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
              "type": "string",
              "pattern": "^clm-[0-9A-HJKMNP-TV-Z]{26}$"
            }
          },
          "evidenceUnitIds": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "string",
              "pattern": "^unit-[0-9A-HJKMNP-TV-Z]{26}$"
            }
          }
        }
      }
    }
  }
}
