{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/answer.schema.json",
  "title": "Answer Composition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "question_id",
    "graph_revision",
    "claim_ids",
    "markdown",
    "facet_states",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "question_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "graph_revision": {
      "type": "integer",
      "minimum": 0
    },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    },
    "facet_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "facet_id",
          "state",
          "reason"
        ],
        "properties": {
          "facet_id": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "enum": [
              "satisfied",
              "partial",
              "missing",
              "conflicting",
              "ambiguous_scope",
              "unsupported_in_snapshot",
              "not_applicable"
            ]
          },
          "source_unit_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
            }
          },
          "claim_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "enum": [
        "evidence_preview",
        "draft_unstable",
        "draft_stable",
        "reviewed",
        "promotable",
        "invalidated",
        "claim_pack_insufficient"
      ]
    },
    "dependency_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
