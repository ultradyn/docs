{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultradyn.dev/schemas/ingest/policy-profile.schema.json",
  "title": "Minimal ingestion policy profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "approved",
    "dataClass",
    "include",
    "exclude",
    "allowedMediaTypes",
    "allowedProcessors",
    "allowedStorage",
    "retentionDays",
    "accessClass",
    "maxFiles",
    "maxFileBytes",
    "maxExpandedBytes"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
    "approved": { "const": true },
    "dataClass": {
      "enum": ["public", "internal", "confidential"]
    },
    "include": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "exclude": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "allowedMediaTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "allowedProcessors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "allowedStorage": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "retentionDays": { "$ref": "#/$defs/positiveInteger" },
    "accessClass": { "$ref": "#/$defs/nonEmptyString" },
    "maxFiles": { "$ref": "#/$defs/positiveInteger" },
    "maxFileBytes": { "$ref": "#/$defs/positiveInteger" },
    "maxExpandedBytes": { "$ref": "#/$defs/positiveInteger" }
  },
  "$comment": "include and exclude must be literal-disjoint; portable Draft 2020-12 cannot compare array values, so the repository-native PolicyProfileSchema enforces this semantic invariant.",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    }
  }
}
