{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "statement",
    "claim_type",
    "scope",
    "authority",
    "lifecycle",
    "status",
    "evidence_refs",
    "created_from"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "enum": [
        "definition",
        "purpose",
        "behavior",
        "requirement",
        "constraint",
        "interface_contract",
        "procedure_step",
        "failure_mode",
        "rationale_documented",
        "example",
        "metric",
        "historical_fact",
        "unknown_boundary"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "disputed",
        "stale",
        "superseded",
        "rejected"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "snapshot_id",
          "source_file_id",
          "source_unit_id",
          "file_sha256",
          "unit_sha256",
          "normalized_path",
          "locator",
          "relation"
        ],
        "properties": {
          "snapshot_id": {
            "type": "string",
            "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
          },
          "source_file_id": {
            "type": "string",
            "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
          },
          "source_unit_id": {
            "type": "string",
            "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
          },
          "file_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "unit_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "normalized_path": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "line",
                  "page",
                  "cell",
                  "slide",
                  "element",
                  "byte",
                  "time"
                ]
              }
            }
          },
          "relation": {
            "enum": [
              "primary",
              "qualifying",
              "example",
              "context_only",
              "conflict",
              "historical"
            ]
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "lifecycle": {
            "type": "string",
            "minLength": 1
          },
          "extraction_tier": {
            "enum": [
              "A_exact",
              "B_verifiable",
              "C_approximate",
              "D_unsupported"
            ]
          }
        }
      }
    },
    "qualifier_claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "contradicts_claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "supersedes_claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "created_from": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "evidence_packet_id"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
        },
        "evidence_packet_id": {
          "type": "string",
          "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
        }
      }
    },
    "semantic_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
