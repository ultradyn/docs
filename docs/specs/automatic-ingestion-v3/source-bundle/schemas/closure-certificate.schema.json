{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/closure-certificate.schema.json",
  "title": "Closure Certificate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "snapshot_id",
    "graph_revision",
    "status",
    "gates",
    "exceptions",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "graph_revision": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "enum": [
        "operational_closed",
        "partial_publish",
        "paused_incomplete",
        "blocked",
        "invalidated"
      ]
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "enum": [
          "pass",
          "fail",
          "waived",
          "not_applicable"
        ]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agent_workflow_versions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    }
  }
}
