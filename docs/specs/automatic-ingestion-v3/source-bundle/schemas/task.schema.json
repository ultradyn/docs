{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/task.schema.json",
  "title": "Implementation Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "work_package_id",
    "title",
    "description",
    "goals",
    "dependencies",
    "deliverables",
    "acceptance_criteria",
    "test_surface",
    "owner_role",
    "estimate_class",
    "risk_level",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^T-[0-9]{2}-[0-9]{2}$"
    },
    "work_package_id": {
      "type": "string",
      "pattern": "^WP-[0-9]{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T-[0-9]{2}-[0-9]{2}$"
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "test_surface": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "unit",
          "schema",
          "contract",
          "integration",
          "workflow",
          "agent_fixture",
          "retrieval",
          "claim",
          "e2e",
          "security",
          "privacy",
          "performance",
          "recovery",
          "human_factors",
          "migration",
          "observability",
          "cost"
        ]
      }
    },
    "owner_role": {
      "type": "string",
      "minLength": 1
    },
    "estimate_class": {
      "enum": [
        "XS",
        "S",
        "M",
        "L",
        "XL"
      ]
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "enum": [
        "planned",
        "ready",
        "blocked",
        "in_progress",
        "done",
        "deferred"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
