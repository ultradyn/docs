{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.local/ingest-v3/schemas/authority-decision.schema.json",
  "title": "Authority Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "subject_claim_ids",
    "decision",
    "scope",
    "effective_from",
    "reason",
    "decided_by",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
    },
    "subject_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    },
    "decision": {
      "enum": [
        "current_authoritative",
        "historical_only",
        "scoped_difference",
        "superseded",
        "unresolved_conflict",
        "requires_human_owner"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "effective_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "effective_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "decided_by": {
      "enum": [
        "policy",
        "agent_proposal",
        "human_authority"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "blocked"
      ]
    },
    "evidence_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{1,5}-[0-9A-HJKMNP-TV-Z]{10,26}$"
      }
    }
  }
}
